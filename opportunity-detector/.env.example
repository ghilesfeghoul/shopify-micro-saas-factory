# ╔══════════════════════════════════════════════════════════════════╗
# ║  .env.example — Opportunity Detector v3                          ║
# ║                                                                   ║
# ║  Two LLM backends supported. Pick one with LLM_BACKEND below.   ║
# ╚══════════════════════════════════════════════════════════════════╝

# ─── Database ─────────────────────────────────────────────────────
DATABASE_URL="file:./prisma/dev.db"


# ╔══════════════════════════════════════════════════════════════════╗
# ║  LLM BACKEND SELECTION                                           ║
# ║                                                                   ║
# ║  "anthropic-api" → uses @anthropic-ai/sdk + ANTHROPIC_API_KEY    ║
# ║                    Pay per token. Best for production / VPS.     ║
# ║                                                                   ║
# ║  "claude-code"   → spawns `claude -p` CLI subprocess              ║
# ║                    Uses your Pro/Max subscription quota.         ║
# ║                    Best for local testing on your Mac.           ║
# ║                                                                   ║
# ║  "auto"          → picks claude-code if no API key is set,        ║
# ║                    otherwise uses anthropic-api                  ║
# ╚══════════════════════════════════════════════════════════════════╝
LLM_BACKEND="anthropic-api"


# ─── Backend 1: Anthropic API ─────────────────────────────────────
# Required if LLM_BACKEND=anthropic-api
# Get key at https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=""
CLAUDE_MODEL="claude-opus-4-7"


# ─── Backend 2: Claude Code CLI ───────────────────────────────────
# Required if LLM_BACKEND=claude-code
#
# Setup:
#   1. Install:   npm install -g @anthropic-ai/claude-code
#   2. Authenticate (interactive once):  claude
#      → Choose "Sign in with Claude.ai" to use your Pro/Max subscription
#   3. Test:  claude -p "say hello" --bare --output-format json
#
# Optional overrides:
CLAUDE_CODE_BINARY="claude"
CLAUDE_CODE_TIMEOUT_MS="300000"
# Leave empty to use the default model from your Claude Code config
CLAUDE_CODE_MODEL=""


# ─── HMAC Authentication ──────────────────────────────────────────
# Generate: openssl rand -hex 32
HMAC_SECRET=""


# ─── IP Allowlist ─────────────────────────────────────────────────
# Tailscale CGNAT range, Docker bridge, and localhost
IP_ALLOWLIST="100.64.0.0/10,172.16.0.0/12,127.0.0.1"


# ─── Server ───────────────────────────────────────────────────────
HOST="127.0.0.1"
PORT="3000"
NODE_ENV="development"


# ─── Logging ──────────────────────────────────────────────────────
LOG_LEVEL="info"


# ─── Scan Limits ──────────────────────────────────────────────────
MAX_SIGNALS_PER_SCAN="200"
MAX_OPPORTUNITIES_PER_SCAN="15"
MIN_SCORE_THRESHOLD="25"


# ─── Product Hunt (optional) ──────────────────────────────────────
PRODUCT_HUNT_TOKEN=""


# ╔══════════════════════════════════════════════════════════════════╗
# ║  Docker Compose stack only (deploy/docker-compose.yml)           ║
# ╚══════════════════════════════════════════════════════════════════╝
POSTGRES_PASSWORD=""
N8N_USER="admin"
N8N_PASSWORD=""
N8N_ENCRYPTION_KEY=""
N8N_HOST="n8n.your-tailnet.ts.net"
DETECTOR_HMAC_SECRET=""
NOTIFICATION_FROM_EMAIL=""
NOTIFICATION_TO_EMAIL=""
