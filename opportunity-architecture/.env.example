# ╔══════════════════════════════════════════════════════════════════╗
# ║  .env.example — Opportunity Architecture                         ║
# ║                                                                   ║
# ║  Generate secrets:                                               ║
# ║    npm run secret:generate                                       ║
# ║  Or:                                                              ║
# ║    openssl rand -hex 32                                          ║
# ╚══════════════════════════════════════════════════════════════════╝

# ─── Database ─────────────────────────────────────────────────────
DATABASE_URL="file:./prisma/architect.db"


# ╔══════════════════════════════════════════════════════════════════╗
# ║  LLM BACKEND SELECTION                                           ║
# ║  Same conventions as opportunity-detector:                       ║
# ║                                                                   ║
# ║  "anthropic-api" → Anthropic API + ANTHROPIC_API_KEY             ║
# ║                    Production / VPS                              ║
# ║                                                                   ║
# ║  "claude-code"   → Claude Code CLI subprocess                    ║
# ║                    Uses Pro/Max subscription                     ║
# ║                                                                   ║
# ║  "auto"          → claude-code if no API key, else api           ║
# ╚══════════════════════════════════════════════════════════════════╝
LLM_BACKEND="anthropic-api"


# ─── Backend 1: Anthropic API ─────────────────────────────────────
ANTHROPIC_API_KEY=""
CLAUDE_MODEL="claude-opus-4-7"


# ─── Backend 2: Claude Code CLI ───────────────────────────────────
CLAUDE_CODE_BINARY="claude"
CLAUDE_CODE_TIMEOUT_MS="1800000"
CLAUDE_CODE_MODEL=""
# Set to "true" to use --bare flag (skip CLAUDE.md/hooks/MCP discovery)
# Default false: uses your Claude Code OAuth session (Pro/Max subscription)
CLAUDE_CODE_USE_BARE="false"


# ─── HMAC Authentication ──────────────────────────────────────────
# Architecture service's own secret (different from detector's)
HMAC_SECRET=""


# ─── IP Allowlist ─────────────────────────────────────────────────
# Tailscale CGNAT range, Docker bridge, localhost
IP_ALLOWLIST="100.64.0.0/10,172.16.0.0/12,127.0.0.1"


# ─── Server ───────────────────────────────────────────────────────
HOST="127.0.0.1"
# IMPORTANT: must differ from detector's port (3000) — default 3001
PORT="3001"
NODE_ENV="development"


# ─── Logging ──────────────────────────────────────────────────────
LOG_LEVEL="info"


# ─── Detector Connection ──────────────────────────────────────────
# URL of the opportunity-detector service this architect calls
DETECTOR_URL="http://localhost:3000"
# HMAC secret for the detector — MUST match the detector's HMAC_SECRET value
# Set this same value in the detector's .env as HMAC_SECRET
DETECTOR_HMAC_SECRET=""


# ─── Auto-trigger Configuration ───────────────────────────────────
# Score threshold above which the poller auto-triggers spec generation
AUTO_TRIGGER_SCORE_THRESHOLD="40"
# Max opportunities fetched per poll cycle
POLL_LIMIT="50"


# ╔══════════════════════════════════════════════════════════════════╗
# ║  Docker Compose stack only (deploy/docker-compose.yml)           ║
# ╚══════════════════════════════════════════════════════════════════╝
N8N_HOST=""
NOTIFICATION_FROM_EMAIL=""
NOTIFICATION_TO_EMAIL=""
