// Prisma schema for opportunity-architecture
// To migrate to PostgreSQL: change `provider` to "postgresql" and update DATABASE_URL

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// Cached opportunities fetched from the detector service (read-only mirror).
// We don't recompute scoring — we trust what the detector tells us.
// This local cache exists so we can:
//   1. Track which opportunities have been spec'd
//   2. Avoid hammering the detector API on every operation
//   3. Provide history even if the opportunity is deleted upstream
model OpportunityCache {
  id                  String    @id @default(cuid())
  opportunityId       String    @unique // OPP-XXXX from detector
  title               String
  problemStatement    String
  totalScore          Int
  priority            String
  suggestedPricing    String
  estimatedDevTime    String
  competitorAnalysis  String
  recommendedFeatures String    // JSON array (mirror of detector)

  // Detector-side status (synced periodically)
  detectorStatus      String    @default("detected")

  // Our local processing flags
  hasActiveSpec       Boolean   @default(false)
  lastSeenAt          DateTime  @default(now())
  cachedAt            DateTime  @default(now())

  // Relations
  specs               ArchitectureSpec[]

  @@index([totalScore, hasActiveSpec])
  @@index([priority])
}

// Technical specifications generated by the Architect Agent.
// One opportunity can have multiple specs (regenerated when prompt changes,
// scope adjustments, etc.) — only one is "active" at a time.
model ArchitectureSpec {
  id              String   @id @default(cuid())
  specId          String   @unique // Human-readable: SPEC-XXXX
  opportunityId   String   // OPP-XXXX (foreign key to OpportunityCache.opportunityId)

  // Core content — JSON canonical form is the single source of truth
  // Markdown is rendered on-demand from this JSON.
  specJson        String   // JSON: full structured TechnicalSpec

  // Quick-access summary fields (denormalized for filtering/sorting)
  appName         String
  shortDescription String
  estimatedHours  Int
  complexityScore Int      // 1-10 (LLM's complexity rating)

  // Versioning — increments when spec is regenerated
  version         Int      @default(1)
  isActive        Boolean  @default(true)

  // Lifecycle status
  status          String   @default("draft")
  // draft | reviewed | approved | building | rejected | archived
  rejectionReason String?

  // Trigger metadata
  triggerMode     String   // "auto" (score>=40 poll) | "manual" | "regenerate" | "api"
  triggeredBy     String?

  // Timestamps
  generatedAt     DateTime @default(now())
  reviewedAt      DateTime?
  approvedAt      DateTime?

  // LLM telemetry
  llmBackend      String   // "anthropic-api" | "claude-code"
  llmModel        String?
  inputTokens     Int?
  outputTokens    Int?
  costUsd         Float?
  durationMs      Int

  // Schema version of the spec (for migration tracking)
  specSchemaVersion String

  // Relations
  cache           OpportunityCache @relation(fields: [opportunityId], references: [opportunityId], onDelete: Cascade)

  @@index([opportunityId, isActive])
  @@index([status, generatedAt])
  @@index([generatedAt])
}

// Tracks each architect run for observability
model ArchitectRun {
  id              String   @id @default(cuid())
  opportunityId   String
  specId          String?  // null if generation failed

  startedAt       DateTime @default(now())
  completedAt     DateTime?
  status          String   @default("running") // running | completed | failed
  errorMessage    String?

  triggerMode     String
  triggerSource   String?

  @@index([startedAt])
  @@index([opportunityId])
  @@index([status])
}

// Tracks polling runs against the detector
model PollRun {
  id                    String   @id @default(cuid())
  startedAt             DateTime @default(now())
  completedAt           DateTime?
  status                String   @default("running")
  opportunitiesFetched  Int      @default(0)
  opportunitiesNew      Int      @default(0)
  autoTriggered         Int      @default(0) // count of auto-generated specs
  errorMessage          String?

  @@index([startedAt])
}
