# ╔══════════════════════════════════════════════════════════════════╗
# ║  .env.example — Opportunity Development                          ║
# ╚══════════════════════════════════════════════════════════════════╝

# ─── Database ─────────────────────────────────────────────────────
DATABASE_URL="file:./prisma/development.db"


# ╔══════════════════════════════════════════════════════════════════╗
# ║  LLM BACKEND                                                     ║
# ║                                                                   ║
# ║  Per architecture decision: Claude Code by default, API fallback ║
# ║  Default: "auto" (Claude Code preferred, API fallback)           ║
# ╚══════════════════════════════════════════════════════════════════╝
LLM_BACKEND="auto"

# Backend 1: Claude Code CLI (preferred for the dev agent)
# Subprocess invocations work with Pro/Max OAuth.
CLAUDE_CODE_BINARY="claude"
CLAUDE_CODE_TIMEOUT_MS="1800000"   # 30 min default per sub-agent
CLAUDE_CODE_MODEL=""               # leave empty to use Claude Code default
# Set to "true" only for short structured outputs (planning).
# Sub-agents that generate code MUST NOT use --bare (they need filesystem tools).
CLAUDE_CODE_USE_BARE="false"

# Backend 2: Anthropic API (fallback for short structured tasks)
ANTHROPIC_API_KEY=""
CLAUDE_MODEL="claude-opus-4-7"


# ─── Authentication ───────────────────────────────────────────────
# This service's OWN secret (for receiving calls from n8n / external)
HMAC_SECRET=""

IP_ALLOWLIST="100.64.0.0/10,172.16.0.0/12,127.0.0.1"


# ─── Server ───────────────────────────────────────────────────────
HOST="127.0.0.1"
PORT="3002"          # IMPORTANT: differs from detector (3000) and architect (3001)
NODE_ENV="development"
LOG_LEVEL="info"


# ─── Architect Connection ─────────────────────────────────────────
# URL of the architect this dev agent calls
ARCHITECT_URL="http://localhost:3001"
# Architect's HMAC secret (for signing outbound calls)
# MUST match the HMAC_SECRET set in the architect service
ARCHITECT_HMAC_SECRET=""


# ─── Workspace ────────────────────────────────────────────────────
# Where generated apps live. Default: ./apps relative to this service.
APPS_ROOT=""

# Git author for autocommits inside generated workspaces
GIT_AUTHOR_NAME="MSF Dev Agent"
GIT_AUTHOR_EMAIL="dev@micro-saas-factory.local"


# ─── Concurrency ──────────────────────────────────────────────────
# How many sub-agents run in parallel (1-10, default 3)
MAX_PARALLEL_SUBAGENTS="3"


# ─── Skills ───────────────────────────────────────────────────────
# Optional: colon-separated extra paths to scan for SKILL.md files.
# Default scans: ~/.claude/skills/, ~/.claude/plugins/
# Example: SKILLS_PATH="/Users/ghiles/work/shopify-skills:/opt/superpowers-skills"
SKILLS_PATH=""
