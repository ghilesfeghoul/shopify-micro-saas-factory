// Prisma schema for opportunity-development
// To migrate to PostgreSQL: change `provider` to "postgresql"

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// Tracks each generation run
model GenerationRun {
  id                  String   @id @default(cuid())
  appId               String   @unique // APP-XXXX
  specId              String   // SPEC-XXXX from architect
  opportunityId       String   // OPP-XXXX from detector

  // Workspace
  workspacePath       String
  hasGitRepo          Boolean  @default(false)

  // Lifecycle
  status              String   @default("pending")
  // pending | planning | generating | integrating | validating | repairing
  // | completed | failed | needs_human_review

  triggerMode         String   // manual | auto | api | retry
  triggeredBy         String?

  // Plan
  totalChunks         Int      @default(0)
  successfulChunks    Int      @default(0)
  failedChunks        Int      @default(0)

  // Validation
  validationPassed    Boolean  @default(false)
  validationFailures  String?  // JSON array of failed step names

  // Compliance
  complianceReportMd  String?  // Markdown report from runShopifyComplianceChecks
  compliancePassed    Boolean  @default(false)

  // Repair loop
  repairAttempts      Int      @default(0)
  maxRepairAttempts   Int      @default(3)

  // LLM telemetry
  totalCostUsd        Float?
  totalDurationMs     Int?

  // Timestamps
  startedAt           DateTime @default(now())
  completedAt         DateTime?

  // Errors
  errorMessage        String?

  // Relations
  chunks              SubAgentTask[]

  @@index([status, startedAt])
  @@index([specId])
  @@index([startedAt])
}

// Tracks individual sub-agent tasks within a run
model SubAgentTask {
  id              String   @id @default(cuid())
  chunkId         String   // Generated by orchestrator (CHK-XXXX)
  generationRunId String

  role            String   // backend | ui | database | tests | config | docs | integrator | repair
  title           String
  instruction     String

  // Dependencies (JSON array of chunk IDs)
  dependencies    String   @default("[]")

  // Expected outputs (JSON array of file paths)
  expectedOutputs String   @default("[]")

  // Execution
  status          String   @default("pending") // pending | running | completed | failed | timeout
  filesCreated    String?  // JSON array
  filesModified   String?  // JSON array

  startedAt       DateTime?
  completedAt     DateTime?
  durationMs      Int?
  costUsd         Float?

  errorMessage    String?

  generationRun   GenerationRun @relation(fields: [generationRunId], references: [id], onDelete: Cascade)

  @@index([generationRunId, status])
  @@index([chunkId])
}
