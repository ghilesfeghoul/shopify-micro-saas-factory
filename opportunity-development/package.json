  "description": "Agent Développeur — orchestrateur multi-sous-agents qui génère des apps Shopify à partir des specs de l'Architecte",
  "main": "dist/api/server.js",
  "scripts": {
    "build": "tsc",
    "dev": "tsx watch src/api/server.ts",
    "start": "node dist/api/server.js",
    "generate": "tsx src/cli.ts generate",
    "list": "tsx src/cli.ts list",
    "show": "tsx src/cli.ts show",
    "retry": "tsx src/cli.ts retry",
    "stats": "tsx src/cli.ts stats",
    "validate": "tsx src/cli.ts validate",
